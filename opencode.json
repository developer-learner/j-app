{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "pm",
  "agent": {
    "pm": {
      "description": "PM agent — translates human intent into PRD, verifies results",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:my-webapp/.opencode/prompts/pm.md}",
      "permission": {
        "edit": { "my-webapp/public/**": "deny", "my-webapp/tests/**": "deny" }
      }
    },
    "architect": {
      "description": "Architect agent — produces engineering plans from approved PRD",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:my-webapp/.opencode/prompts/architect.md}",
      "permission": {
        "edit": { "my-webapp/public/**": "deny", "my-webapp/tests/**": "deny" }
      }
    },
    "build": {
      "description": "Build agent — implements code per PRD + architecture",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:my-webapp/.opencode/prompts/build.md}",
      "permission": {
        "edit": { "my-webapp/tests/**": "deny", "**": "allow" }
      }
    },
    "test": {
      "description": "Test agent — writes tests from PRD acceptance criteria",
      "mode": "primary",
      "model": "anthropic/claude-opus-4-8",
      "prompt": "{file:my-webapp/.opencode/prompts/test.md}",
      "permission": {
        "edit": { "my-webapp/public/**": "deny", "my-webapp/tests/**": "allow" }
      }
    }
  }
}
